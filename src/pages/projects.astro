---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import overrides from "../data/projects-overrides.json";
import { fetchGitHubRepos } from "../lib/github";
import { featuredRepos, site } from "../config/site";

const token = import.meta.env.GITHUB_TOKEN;
let repos = [];
let fetchError: string | null = null;

try {
  repos = await fetchGitHubRepos("souravakib", token);
} catch (error) {
  fetchError =
    error instanceof Error ? error.message : "Unable to load GitHub projects.";
}

const featuredSet = new Set<string>(featuredRepos);
const featured = repos.filter((repo) => featuredSet.has(repo.name));
const other = repos.filter((repo) => !featuredSet.has(repo.name));

function getDescription(name: string, fallback: string | null) {
  const override = overrides[name as keyof typeof overrides];
  return override?.description ?? fallback;
}
---

<Layout
  title={`${site.name} — Projects`}
  description={`Open-source and research projects by ${site.name} on GitHub.`}
>
  <div class="mb-10">
    <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">Projects</h1>
    <p class="prose-muted mt-3 max-w-2xl">
      Public repositories from my GitHub profile, with research and ML work featured first.
    </p>
  </div>

  {
    fetchError ? (
      <div class="card border-amber-500/30 bg-amber-500/10 text-amber-100">
        <p class="font-medium">Projects could not be loaded at build time.</p>
        <p class="mt-2 text-sm text-amber-100/80">{fetchError}</p>
        <a
          href={site.github}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary mt-4"
        >
          View on GitHub
        </a>
      </div>
    ) : (
      <>
        <section class="mb-12">
          <Section title="Featured" />
          <div class="grid gap-6 sm:grid-cols-2">
            {featured.map((repo) => (
              <ProjectCard
                repo={repo}
                featured
                description={getDescription(repo.name, repo.description)}
              />
            ))}
          </div>
        </section>

        {other.length > 0 && (
          <section>
            <Section title="Other Projects" />
            <div class="grid gap-6 sm:grid-cols-2">
              {other.map((repo) => (
                <ProjectCard
                  repo={repo}
                  description={getDescription(repo.name, repo.description)}
                />
              ))}
            </div>
          </section>
        )}
      </>
    )
  }
</Layout>
