---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import { site } from "../config/site";

const calendlyEmbedUrl = site.calendlyEmbedUrl;
const calendlyPageUrl = site.calendlyUrl || calendlyEmbedUrl;
---

<Layout
  title={`${site.name} — Availability`}
  description={`Schedule a meeting with ${site.name}.`}
>
  <div class="mb-8">
    <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">Availability</h1>
    <p class="prose-muted mt-3 max-w-2xl">
      Pick a time that works for you. My calendar stays in sync through Calendly.
    </p>
  </div>

  <section class="card overflow-hidden p-0">
    <div class="border-b border-surface-border px-6 py-4">
      <Section title="Book a Meeting" />
      <p class="text-sm text-slate-400">
        Prefer opening Calendly directly?
        <a
          href={calendlyPageUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 text-accent-muted hover:text-white"
        >
          Open scheduling page
        </a>
      </p>
    </div>

    <div class="min-h-[700px] w-full bg-white">
      <iframe
        src={calendlyEmbedUrl}
        title="Schedule a meeting with Sourav Akib Sarkar"
        width="100%"
        height="700"
        frameborder="0"
        class="block w-full"
      />
    </div>

    <noscript>
      <div class="p-6 text-sm text-slate-300">
        JavaScript is required for the embedded scheduler. Visit
        <a href={calendlyPageUrl} class="text-accent-muted">{calendlyPageUrl}</a>
        to book a meeting.
      </div>
    </noscript>
  </section>
</Layout>
