---
import type { GitHubRepo } from "../lib/github";
import { formatDate } from "../lib/github";

interface Props {
  repo: GitHubRepo;
  description?: string;
  featured?: boolean;
}

const { repo, description, featured = false } = Astro.props;
const displayDescription = description ?? repo.description ?? "No description provided.";
---

<article
  class:list={[
    "card flex h-full flex-col transition hover:border-accent/40",
    featured && "ring-1 ring-accent/20",
  ]}
>
  <div class="mb-4 flex items-start justify-between gap-3">
    <div>
      <h3 class="font-display text-lg font-semibold text-white">
        <a
          href={repo.html_url}
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-accent-muted"
        >
          {repo.name}
        </a>
      </h3>
      {
        featured && (
          <span class="mt-2 inline-block rounded-full bg-accent/15 px-2.5 py-0.5 text-xs font-medium text-accent-muted">
            Featured
          </span>
        )
      }
    </div>
    <span class="shrink-0 text-xs text-slate-400">★ {repo.stargazers_count}</span>
  </div>

  <p class="prose-muted mb-4 flex-1 text-sm">{displayDescription}</p>

  <div class="flex flex-wrap items-center gap-2 text-xs text-slate-400">
    {
      repo.language && (
        <span class="rounded-full border border-surface-border px-2.5 py-1">
          {repo.language}
        </span>
      )
    }
    <span>Updated {formatDate(repo.updated_at)}</span>
  </div>
</article>
